# LLM Configuration
# 生产环境用 DeepSeek: https://api.deepseek.com/v1, model: deepseek-v4-flash
# 测试环境用小米 MiMo: https://token-plan-cn.xiaomimimo.com/v1, model: mimo-v2.5-pro
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# Server
PORT=8080
JWT_SECRET=change-me-in-production

# Database
DB_PATH=./data/ops-agent.db
